{
  "name": "@omnicell/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13 <25"
  },
  "packageManager": "npm@11.3.0",
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:check": "node scripts/check-contracts.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:api": "vitest run src/api",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:live": "../.venv/bin/python ../scripts/test_live_e2e.py",
    "build": "npm run contracts:check && tsc -b && vite build"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.4",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eventsource-parser": "3.1.0",
    "openapi-fetch": "0.17.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-router": "7.18.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "json-schema-to-typescript": "15.0.4",
    "msw": "2.15.0",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
