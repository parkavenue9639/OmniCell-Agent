# ==============================================================================
# OpenRouter Configuration (Recommended)
# ==============================================================================
# 您的 OpenRouter API 密钥
OPENROUTER_API_KEY=""

# Base URL (通常无需更改)
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# 默认使用的模型名称 (如: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet)
DEFAULT_OPENROUTER_MODEL="openai/gpt-4o-mini"

# ==============================================================================
# OneRouter Configuration (Debugging Environment)
# ==============================================================================
# 直连 OneRouter 等兼容平台的配置
ONEROUTER_API_KEY=""
ONEROUTER_BASE_URL="https://llm.onerouter.pro/v1"
DEFAULT_ONEROUTER_MODEL="gemini-2.5-flash"

# ==============================================================================
# LLM 角色别名
# ==============================================================================
# target 格式为 provider/model；model 本身可以继续包含 `/`。
# 单个角色留空时回落到 OMNICELL_LLM_DEFAULT，无需修改 Graph A/B 领域代码。
OMNICELL_LLM_DEFAULT="openrouter/default"
OMNICELL_LLM_AGENT_PRIMARY=""
OMNICELL_LLM_FAST_ROUTER=""
OMNICELL_LLM_CODE_GENERATION=""
OMNICELL_LLM_ANNOTATION=""
OMNICELL_LLM_VALIDATION=""
OMNICELL_LLM_SUMMARY=""
OMNICELL_LLM_VISION=""
# 由运维显式声明 vision target 接受的输入模态；与角色最低能力不匹配时启动失败。
OMNICELL_LLM_VISION_INPUT_MODALITIES="text,image"

# ==============================================================================
# PostgreSQL Persistence
# ==============================================================================
# 本地开发默认与 infra/compose.yaml 一致；生产环境必须替换账号、密码和地址。
OMNICELL_POSTGRES_DSN="postgresql://omnicell:omnicell_dev@127.0.0.1:55432/omnicell"
OMNICELL_POSTGRES_APP_SCHEMA="omnicell_app"
OMNICELL_POSTGRES_CHECKPOINT_SCHEMA="omnicell_checkpoint"
OMNICELL_POSTGRES_POOL_MIN="1"
OMNICELL_POSTGRES_POOL_MAX="8"
OMNICELL_POSTGRES_CONNECT_TIMEOUT="10"

# Conversation workspace 根目录。大型科学数据和 artifact 保存于此，不进入 PostgreSQL。
OMNICELL_WORKSPACE_ROOT="data/conversations"

# 本地 API 默认只监听 loopback；若要开放 LAN 必须显式修改并同步配置鉴权边界。
OMNICELL_API_HOST="127.0.0.1"
OMNICELL_API_PORT="8000"

# ==============================================================================
# Local Docker Backend
# ==============================================================================
# 本地开发默认使用 infra/docker/Dockerfile.worker 对应镜像。
OMNICELL_RUNTIME_IMAGE="omnicell-worker:latest"
